# Отримати ключ: https://www.football-data.org/client/register
FOOTBALL_API_KEY=your_football_api_key_here

# Отримати токен: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ID чату/каналу (наприклад: -1001234567890)
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Список змагань (через кому, опціонально)
FOOTBALL_COMPETITIONS=FIFA World Cup,European Championship,UEFA Nations League,UEFA Champions League,UEFA Europa League,UEFA Conference League,FIFA Club World Cup

# На скільки днів вперед дивитись (опціонально, за замовчуванням 7)
DAYS_AHEAD=7

# Зсув часового поясу відносно UTC (опціонально, за замовчуванням 3 для Києва)
TIMEZONE_OFFSET=3
